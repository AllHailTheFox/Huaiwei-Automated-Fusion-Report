# FusionSolar credentials
FUSIONSOLAR_USERNAME=your_fusionsolar_email@gmail.com
FUSIONSOLAR_PASSWORD=your_fusionsolar_password

# Gmail app-specific password (not your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Comma-separated list of recipient email addresses
RECIPIENT_EMAILS=you@gmail.com,partner@gmail.com

# FusionSolar station ID (find it in the monitoring page URL)
STATION_ID=72289258
