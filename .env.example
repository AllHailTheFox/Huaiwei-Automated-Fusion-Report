# FusionSolar credentials
FUSIONSOLAR_USERNAME=your_fusionsolar_email@gmail.com
FUSIONSOLAR_PASSWORD=your_fusionsolar_password

# FusionSolar portal base URL (change for regional variants)
FUSIONSOLAR_BASE_URL=https://intl.fusionsolar.huawei.com

# Gmail app-specific password (NOT your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# Copy exactly as shown — spaces are stripped automatically
EMAIL_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# Comma-separated list of recipient email addresses
RECIPIENT_EMAILS=you@gmail.com,partner@yahoo.com

# FusionSolar station ID (found in the monitoring page URL after NE=)
SITE_ID=72289258

# Day of month your electricity bill resets
BILLING_DAY=15

# Heat loss percentage deducted from exported energy (e.g. 6 = 6%)
HEAT_LOSS_PERCENT=5

# Cron schedule for the weekly report (5-field cron syntax).
# Default: every Friday at 8:00 AM. See crontab.example for more options.
CRON_SCHEDULE=0 8 * * 5

# Set to "true" to fire one report immediately when the container starts.
# Useful for testing — REMEMBER to set back to "false" afterwards.
RUN_ON_START=false
