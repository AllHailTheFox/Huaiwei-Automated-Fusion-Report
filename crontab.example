# FusionSolar Weekly Report — scheduling options
#
# Pick ONE approach:
#   A) Native Linux cron (simple) — this file
#   B) Docker cron (container with internal cron) — see docker-compose.yml
#
# ── A) Native Linux cron ──────────────────────────────────────────────────
#
# Prerequisites:
#   1. python3 + pip packages installed (pip install -r requirements.txt)
#   2. playwright install chromium
#   3. .env file in the project root with your credentials
#
# Add this to your user crontab (crontab -e):
#
#   0 8 * * 5 /path/to/run.sh >> /path/to/report.log 2>&1
#
# Run a one-off preview:
#   /path/to/run.sh --preview
#
# Send email now:
#   /path/to/run.sh
#
# ── B) Docker cron ────────────────────────────────────────────────────────
#
# Uses CRON_SCHEDULE env var from .env. Container runs cron internally.
#
# Rebuild + start:
#   docker compose up -d --build
#
# One-off run (doesn't touch running container):
#   docker compose run --rm fusionsolar-extractor python /app/main.py
#
# Preview:
#   docker compose run --rm fusionsolar-extractor python /app/main.py --preview
